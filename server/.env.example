PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
APP_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=blogging_website

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Optional: MongoDB is used only for logs/drafts. Leave blank to skip.
MONGODB_URI=
MONGODB_LOG_DB_NAME=blogging_logs
MONGODB_SERVER_SELECTION_TIMEOUT_MS=1500

# Optional: Redis is used only for caching. Leave blank to skip.
REDIS_URL=
REDIS_CONNECT_TIMEOUT_MS=1000
